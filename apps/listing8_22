#include "main.hpp"
#include <embedDIP.hpp>

using namespace std;

int application() {
  embedDIP::Image inImg(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image fftImg(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image filteredImg(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image filter(256, 256, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Image outImg(256, 256, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Serial serial(&stm32_uart);

  serial.init();

  serial.capture(inImg);
  inImg.fft(fftImg);
  fftImg.fftshift();

  filter.getFilter(FREQ_FILTER_GAUSSIAN_LOWPASS, 30.0f);
  fftImg.ffilter2D(filter, filteredImg);
  filteredImg.fftshift();
  filteredImg.ifft(filteredImg);

  inImg.difference(filteredImg, outImg);
  outImg.convertTo();
  serial.send(outImg);

  while (1) {
    ;
  }
}
