#include "main.hpp"
#include <embedDIP.hpp>

using namespace std;

int application() {
  embedDIP::Image inImg(IMAGE_RES_WQVGA, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image outImg(IMAGE_RES_WQVGA, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Serial serial(&stm32_uart);

  serial.init();

  vector<vector<float>> lowPassFilter3x3(3, vector<float>(3, 1.0f / 9.0f));
  vector<vector<float>> lowPassFilter5x5(5, vector<float>(5, 1.0f / 25.0f));

  serial.capture(inImg);

  inImg.filter2D(lowPassFilter3x3, outImg);
  outImg.convertTo();
  serial.send(outImg);

  inImg.filter2D(lowPassFilter5x5, outImg);
  outImg.convertTo();
  serial.send(outImg);

  while (1) {
    ;
  }
}