#include "main.hpp"
#include <embedDIP.hpp>

using namespace std;

int application() {
  embedDIP::Image inImg(IMAGE_RES_WQVGA, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image outImg(IMAGE_RES_WQVGA, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Serial serial(&stm32_uart);

  serial.init();

  vector<vector<float>> highPassFilter3x3 = {
      {1, 0, -1}, {2, 0, -2}, {1, 0, -1}};

  serial.capture(inImg);

  inImg.filter2D(highPassFilter3x3, outImg);
  outImg.convertTo();
  serial.send(outImg);

  while (1) {
    ;
  }
}