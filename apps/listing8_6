#include "main.hpp"
#include <embedDIP.hpp>

using namespace std;

int application() {
  embedDIP::Image inImg(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image outImg(256, 256, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Image boatMagnitude(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image boatPhase(256, 256, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Image mandrillImage(256, 256, IMAGE_FORMAT_GRAYSCALE);
  embedDIP::Image mandrillPhase(256, 256, IMAGE_FORMAT_GRAYSCALE);

  embedDIP::Serial serial(&stm32_uart);

  serial.init();

  // Capture Boat
  serial.capture(inImg);
  inImg.fft(inImg);
  inImg._abs_(boatMagnitude);
  inImg._phase_(boatPhase);

  // Capture Magnitude
  serial.capture(inImg);
  inImg.fft(inImg);
  inImg._abs_(mandrillImage);
  inImg._phase_(mandrillPhase);

  // Boat's Magnitude + Baboon's Phase
  outImg.polarToCart(boatMagnitude, mandrillPhase);
  outImg.ifft(outImg);
  outImg.convertTo();
  serial.send(outImg);

  // Baboon's Magnitude + Boat's Phase
  outImg.polarToCart(mandrillImage, boatPhase);
  outImg.ifft(outImg);
  outImg.convertTo();
  serial.send(outImg);

  while (1) {
    ;
  }
}